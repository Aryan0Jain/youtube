music/*.mp3
assets/*.ttf
fonts/*.ttf
fonts/*.otf

# ── Job database ──────────────────────────────────────────────────────────────
data/jobs.db

# ── IDE / editor ──────────────────────────────────────────────────────────────
.claude/
.idea/
.vscode/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
