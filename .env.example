# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Pexels ─────────────────────────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_key_here

# ── Google (shared service account for Sheets + TTS + GCS) ────────────────────
GOOGLE_SA_KEY_PATH=config/credentials/service_account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Dashboard ──────────────────────────────────────────────────────────────────
# Uncomment to expose dashboard on all interfaces (use SSH tunnel instead)
# FLASK_HOST=0.0.0.0

# ── Development mock flags ─────────────────────────────────────────────────────
# Set any of these to "1" to skip the real API call during local testing:
# USE_MOCK_CLAUDE=1       → generates dummy script text
# USE_MOCK_TTS=1          → writes a silent MP3 instead of calling TTS API
# USE_MOCK_PEXELS=1       → copies clips from tests/fixtures/clips/
# USE_MOCK_YOUTUBE=1      → skips upload, returns a fake video ID
# USE_MOCK_SHEETS=1       → reads topics from tests/fixtures/sheet.csv

# ── Orchestrator tuning ────────────────────────────────────────────────────────
# POLL_INTERVAL=30        → seconds between job queue checks (default: 30)
